generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── テナント (= 企業) ────────────────────────────────────────────
model Tenant {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  serankingProjectId String?
  ownDomain          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users           User[]
  aeoPrompts      AeoPrompt[]
  aeoCompetitors  AeoCompetitor[]
  aeoSnapshots    AeoRankSnapshot[]
  approvalItems   ApprovalItem[]
  gscConnection      GscConnection?
  seoKeywords        SeoKeyword[]
  seoKeywordSnaps    SeoKeywordSnapshot[]
  seoArticles        SeoArticle[]
  hubspotConnection  HubSpotConnection?
  nurtureLeads       NurtureLead[]
  nurtureSegments    NurtureSegment[]
  nurtureEmailDrafts NurtureEmailDraft[]
  ga4Connection      Ga4Connection?
  ga4DailyMetrics    Ga4DailyMetric[]
}

// ─── ユーザー ─────────────────────────────────────────────────────
model User {
  id       String   @id @default(cuid())
  clerkId  String   @unique
  tenantId String
  email    String
  name     String?
  role     UserRole @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

// ─── AEO ──────────────────────────────────────────────────────────

enum AeoEngine {
  CHATGPT
  PERPLEXITY
  GEMINI
  GOOGLE_AI_OVERVIEW
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model AeoPrompt {
  id                String   @id @default(cuid())
  tenantId          String
  text              String
  serankingPromptId String?
  industry          String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  snapshots   AeoRankSnapshot[]
  competitors AeoCompetitor[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model AeoCompetitor {
  id        String   @id @default(cuid())
  tenantId  String
  promptId  String
  domain    String
  createdAt DateTime @default(now())

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prompt AeoPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([tenantId, promptId, domain])
  @@index([tenantId])
  @@index([promptId])
}

model AeoRankSnapshot {
  id           String    @id @default(cuid())
  tenantId     String
  promptId     String
  engine       AeoEngine
  snapshotDate DateTime
  ownDomain    String?
  ownRank      Int?
  citations    Json
  rawResponse  Json?
  createdAt    DateTime  @default(now())

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prompt AeoPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([tenantId, promptId, engine, snapshotDate])
  @@index([tenantId])
  @@index([tenantId, promptId])
  @@index([tenantId, snapshotDate])
}

model ApprovalItem {
  id         String         @id @default(cuid())
  tenantId   String
  module     String
  type       String
  payload    Json
  status     ApprovalStatus @default(PENDING)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  reviewedAt DateTime?
  reviewedBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, module])
}

// ─── SEO ──────────────────────────────────────────────────────────

model GscConnection {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  email        String
  siteUrl      String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SeoKeyword {
  id        String   @id @default(cuid())
  tenantId  String
  text      String
  intent    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  snapshots SeoKeywordSnapshot[]
  articles  SeoArticle[]

  @@unique([tenantId, text])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

model SeoKeywordSnapshot {
  id           String   @id @default(cuid())
  tenantId     String
  keywordId    String
  snapshotDate DateTime
  clicks       Int
  impressions  Int
  ctr          Float
  position     Float
  createdAt    DateTime @default(now())

  tenant  Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  keyword SeoKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([tenantId, keywordId, snapshotDate])
  @@index([tenantId])
  @@index([tenantId, keywordId])
  @@index([tenantId, snapshotDate])
}

model SeoArticle {
  id         String         @id @default(cuid())
  tenantId   String
  keywordId  String?
  title      String
  brief      String         @db.Text
  draft      String?        @db.Text
  status     ApprovalStatus @default(PENDING)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  reviewedAt DateTime?
  reviewedBy String?

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  keyword SeoKeyword? @relation(fields: [keywordId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
}

// ─── ナーチャリング ────────────────────────────────────────────────

model HubSpotConnection {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  portalId  String
  apiKey    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model NurtureLead {
  id           String   @id @default(cuid())
  tenantId     String
  hubspotId    String
  email        String
  firstName    String?
  lastName     String?
  company      String?
  jobTitle     String?
  lifecycle    String?
  leadStatus   String?
  icpScore     Int      @default(0)
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  segments NurtureLeadSegment[]

  @@unique([tenantId, hubspotId])
  @@index([tenantId])
  @@index([tenantId, lifecycle])
  @@index([tenantId, icpScore])
}

model NurtureSegment {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  criteria    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads  NurtureLeadSegment[]
  drafts NurtureEmailDraft[]

  @@index([tenantId])
}

model NurtureLeadSegment {
  leadId    String
  segmentId String

  lead    NurtureLead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  segment NurtureSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@id([leadId, segmentId])
}

model NurtureEmailDraft {
  id         String         @id @default(cuid())
  tenantId   String
  segmentId  String?
  subject    String
  body       String         @db.Text
  status     ApprovalStatus @default(PENDING)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  reviewedAt DateTime?
  reviewedBy String?

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  segment NurtureSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
}

// ─── アナリティクス (GA4) ─────────────────────────────────────────

model Ga4Connection {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  propertyId   String
  email        String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Ga4DailyMetric {
  id              String   @id @default(cuid())
  tenantId        String
  date            DateTime
  sessions        Int      @default(0)
  users           Int      @default(0)
  newUsers        Int      @default(0)
  pageviews       Int      @default(0)
  organicSessions Int      @default(0)
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId])
  @@index([tenantId, date])
}
