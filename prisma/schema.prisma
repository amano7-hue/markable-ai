generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── テナント (= 企業) ────────────────────────────────────────────
model Tenant {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  serankingProjectId String?
  ownDomain          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  slackWebhookUrl      String?
  serankingCreditBudget Int     @default(10000)
  wpUrl                String?
  wpUsername           String?
  wpAppPassword        String?
  resendFrom           String?

  users              User[]
  projects           Project[]
  approvalItems      ApprovalItem[]
  aeoPrompts         AeoPrompt[]
  aeoCompetitors     AeoCompetitor[]
  aeoSnapshots       AeoRankSnapshot[]
  gscConnections     GscConnection[]
  ga4Connections     Ga4Connection[]
  ga4DailyMetrics    Ga4DailyMetric[]
  seoKeywords        SeoKeyword[]
  seoKeywordSnaps    SeoKeywordSnapshot[]
  seoArticles        SeoArticle[]
  hubspotConnections HubSpotConnection[]
  brandProfiles      BrandProfile[]
  knowledgeSources   KnowledgeSource[]
  ctaBlocks          CtaBlock[]
  articleDiagrams    SeoArticleDiagram[]
  articleTables      SeoArticleTable[]
  nurtureLeads          NurtureLead[]
  nurtureSegments       NurtureSegment[]
  nurtureEmailDrafts    NurtureEmailDraft[]
  serankingApiLogs      SerankingApiLog[]
  icpConfig             IcpConfig?
  projectInvites        ProjectInvite[]
  articleLinks          ProjectArticleLink[]
  aeoProjectCompetitors AeoProjectCompetitor[]
}

// ─── プロジェクト (= ドメイン単位) ────────────────────────────────
model Project {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  ownDomain        String?
  isDefault        Boolean  @default(false)
  ga4ChannelFilter String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aeoPrompts           AeoPrompt[]
  aeoCompetitors       AeoCompetitor[]
  aeoProjectCompetitors AeoProjectCompetitor[]
  aeoSnapshots         AeoRankSnapshot[]
  gscConnection    GscConnection?
  ga4Connection    Ga4Connection?
  ga4DailyMetrics  Ga4DailyMetric[]
  hubspotConnection  HubSpotConnection?
  nurtureLeads     NurtureLead[]
  nurtureSegments  NurtureSegment[]
  nurtureEmailDrafts NurtureEmailDraft[]
  seoKeywords      SeoKeyword[]
  seoKeywordSnaps  SeoKeywordSnapshot[]
  seoArticles      SeoArticle[]
  brandProfile     BrandProfile?
  knowledgeSources KnowledgeSource[]
  ctaBlocks        CtaBlock[]
  members          ProjectMember[]
  invites          ProjectInvite[]
  articleLinks     ProjectArticleLink[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

// ─── プロジェクトメンバー ────────────────────────────────────────
model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(VIEWER)
  createdAt DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

// ─── プロジェクト招待 ─────────────────────────────────────────────
model ProjectInvite {
  id         String      @id @default(cuid())
  projectId  String
  tenantId   String
  email      String?     // リンク招待の場合は null
  role       ProjectRole @default(VIEWER)
  token      String      @unique @default(cuid())
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([token])
}

enum ProjectRole {
  EDITOR  // 編集・承認操作可
  VIEWER  // 閲覧のみ
}

// ─── ユーザー ─────────────────────────────────────────────────────
model User {
  id       String   @id @default(cuid())
  clerkId  String   @unique
  tenantId String
  email    String
  name     String?
  role     UserRole @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectMembers ProjectMember[]

  @@index([tenantId])
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

// ─── AEO ──────────────────────────────────────────────────────────

enum AeoEngine {
  CHATGPT
  PERPLEXITY
  GEMINI
  GOOGLE_AI_OVERVIEW
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model AeoPrompt {
  id                String   @id @default(cuid())
  tenantId          String
  projectId         String?
  text              String
  serankingPromptId String?
  industry          String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project     Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshots   AeoRankSnapshot[]
  competitors AeoCompetitor[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([projectId])
}

model AeoCompetitor {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String?
  promptId  String
  domain    String
  createdAt DateTime @default(now())

  tenant  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  prompt  AeoPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([tenantId, promptId, domain])
  @@index([tenantId])
  @@index([promptId])
  @@index([projectId])
}

// プロジェクト全体で管理する競合ドメイン（全プロンプトに適用）
model AeoProjectCompetitor {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String
  domain    String
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, domain])
  @@index([tenantId])
  @@index([projectId])
}

model AeoRankSnapshot {
  id           String    @id @default(cuid())
  tenantId     String
  projectId    String?
  promptId     String
  engine       AeoEngine
  snapshotDate DateTime
  ownDomain    String?
  ownRank      Int?
  citations    Json
  rawResponse  Json?
  createdAt    DateTime  @default(now())

  tenant  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  prompt  AeoPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([tenantId, promptId, engine, snapshotDate])
  @@index([tenantId])
  @@index([tenantId, promptId])
  @@index([tenantId, snapshotDate])
  @@index([projectId])
}

model ApprovalItem {
  id         String         @id @default(cuid())
  tenantId   String
  projectId  String?
  module     String
  type       String
  payload    Json
  status     ApprovalStatus @default(PENDING)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  reviewedAt DateTime?
  reviewedBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, module])
  @@index([projectId])
}

// ─── SEO ──────────────────────────────────────────────────────────

model GscConnection {
  id           String   @id @default(cuid())
  tenantId     String
  projectId    String?  @unique
  email        String
  siteUrl      String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SeoKeyword {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String?
  text      String
  intent    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project   Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshots SeoKeywordSnapshot[]
  articles  SeoArticle[]

  @@unique([tenantId, projectId, text])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([projectId])
}

model SeoKeywordSnapshot {
  id           String   @id @default(cuid())
  tenantId     String
  projectId    String?
  keywordId    String
  snapshotDate DateTime
  clicks       Int
  impressions  Int
  ctr          Float
  position     Float
  createdAt    DateTime @default(now())

  tenant  Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  keyword SeoKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([tenantId, projectId, keywordId, snapshotDate])
  @@index([tenantId])
  @@index([tenantId, keywordId])
  @@index([tenantId, snapshotDate])
  @@index([projectId])
}

model SeoArticle {
  id         String         @id @default(cuid())
  tenantId   String
  projectId  String?
  keywordId  String?
  title      String
  analysis       Json?          // 読者ニーズ・競合分析・推奨文字数
  brief          String         @db.Text
  draft          String?        @db.Text
  seoTitle         String?        @db.Text  // SEO用タイトル (60文字以内・キーワード先頭)
  seoDescription   String?        @db.Text  // メタディスクリプション (120-150文字)
  featuredImageUrl String?        @db.Text  // Vercel Blob URL
  sourceContent  String?        @db.Text  // リライト元記事（差分表示用）
  rewriteReasons String?        @db.Text  // リライト理由・改善指示 JSON string[]
  draftStage     String?                    // "ANALYZING" | "REVIEWING" | null
  status         ApprovalStatus @default(PENDING)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  reviewedAt DateTime?
  reviewedBy String?

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project  Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  keyword  SeoKeyword?        @relation(fields: [keywordId], references: [id], onDelete: SetNull)
  diagrams SeoArticleDiagram[]
  tables   SeoArticleTable[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([projectId])
}

// ─── 記事図解 ────────────────────────────────────────────────────

model SeoArticleDiagram {
  id          String     @id @default(cuid())
  tenantId    String
  articleId   String
  marker      String     // e.g. "diag-1" → [diagram:diag-1] in draft
  title       String     // キャプション
  mermaidCode String     @db.Text
  imageUrl    String?    @db.Text  // Imagen生成画像 (Vercel Blob URL)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  article SeoArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tenant  Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([articleId, marker])
  @@index([tenantId])
  @@index([articleId])
}

// ─── 記事テーブル ──────────────────────────────────────────────────

model SeoArticleTable {
  id          String     @id @default(cuid())
  tenantId    String
  articleId   String
  marker      String     // e.g. "table-1" → [table:table-1] in draft
  title       String     // キャプション
  htmlContent String     @db.Text  // <table>...</table> HTML
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  article SeoArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tenant  Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([articleId, marker])
  @@index([tenantId])
  @@index([articleId])
}

// ─── プロジェクト関連記事リンク ────────────────────────────────────

model ProjectArticleLink {
  id         String   @id @default(cuid())
  tenantId   String
  projectId  String
  title      String
  url        String   @db.Text
  keywords   String?  @db.Text  // カンマ区切りのキーワード
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([projectId])
}

// ─── CTA ブロック ─────────────────────────────────────────────────

model CtaBlock {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String?
  shortcode String   // e.g. "contact", "trial", "download"
  label     String   // 管理用表示名
  content   String   @db.Text  // HTML コンテンツ
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([tenantId, projectId, shortcode])
  @@index([tenantId])
  @@index([projectId])
}

// ─── ナーチャリング ────────────────────────────────────────────────

model HubSpotConnection {
  id           String   @id @default(cuid())
  tenantId     String
  projectId    String   @unique
  portalId     String
  apiKey       String
  importFilter Json?    // { lifecycles?: string[], leadStatuses?: string[] }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model NurtureLead {
  id           String   @id @default(cuid())
  tenantId     String
  projectId    String
  hubspotId    String
  email        String
  firstName    String?
  lastName     String?
  company      String?
  jobTitle     String?
  lifecycle    String?
  leadStatus   String?
  numberOfEmployees Int?
  annualRevenue     Float?
  icpScore          Int      @default(0)
  emailOpenCount    Int?     @default(0)
  emailClickCount   Int?     @default(0)
  lastEmailOpenAt   DateTime?
  lastSyncedAt      DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project  Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  segments NurtureLeadSegment[]

  @@unique([projectId, hubspotId])
  @@index([tenantId])
  @@index([projectId])
  @@index([tenantId, lifecycle])
  @@index([tenantId, icpScore])
}

model NurtureSegment {
  id          String   @id @default(cuid())
  tenantId    String
  projectId   String?
  name        String
  description String?
  criteria    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  leads   NurtureLeadSegment[]
  drafts  NurtureEmailDraft[]

  @@index([tenantId])
  @@index([projectId])
}

model IcpConfig {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  answers     Json     // ユーザーが回答したアンケート内容
  rules       Json     // AI生成スコアリングルール
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model NurtureLeadSegment {
  leadId    String
  segmentId String

  lead    NurtureLead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  segment NurtureSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@id([leadId, segmentId])
}

model NurtureEmailDraft {
  id         String         @id @default(cuid())
  tenantId   String
  projectId  String?
  segmentId  String?
  subject    String
  body       String         @db.Text
  status     ApprovalStatus @default(PENDING)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  reviewedAt DateTime?
  reviewedBy String?

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  segment NurtureSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([projectId])
  @@index([tenantId, status])
}

// ─── API 使用状況ログ ─────────────────────────────────────────────

model SerankingApiLog {
  id           String   @id @default(cuid())
  tenantId     String
  operation    String   // "airt_sync" | "leaderboard"
  creditsUsed  Int
  promptCount  Int?     // AIRT 同期の場合: 処理プロンプト数
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

// ─── アナリティクス (GA4) ─────────────────────────────────────────

model Ga4Connection {
  id           String   @id @default(cuid())
  tenantId     String
  projectId    String?  @unique
  propertyId   String
  email        String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Ga4DailyMetric {
  id              String   @id @default(cuid())
  tenantId        String
  projectId       String
  date            DateTime
  sessions        Int      @default(0)
  users           Int      @default(0)
  newUsers        Int      @default(0)
  pageviews       Int      @default(0)
  organicSessions Int      @default(0)
  createdAt       DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([tenantId, projectId, date])
  @@index([tenantId])
  @@index([projectId])
}

// ─── ブランドプロファイル ─────────────────────────────────────────
model BrandProfile {
  id                 String   @id @default(cuid())
  tenantId           String
  projectId          String?  @unique
  tone                   String?  // formal | casual | friendly | technical
  toneRules              Json     @default("[]")  // string[] カスタム文体ルール
  companyDescription     String?  @db.Text
  ngWords                Json     @default("[]")  // string[]
  preferredPhrases       Json     @default("[]")  // { from: string; to: string }[]
  writingModel           String   @default("gemini-2.5-flash")  // 記事本文生成モデル
  diagramPreference      String?  // "auto" | "flowchart" | "sequenceDiagram" | "graph"
  diagramInstructions    String?  @db.Text
  imageStyleInstructions String?  @db.Text
  decorationRules        String?  @db.Text  // 装飾ルール（1行1ルール）例: "重要なキーワードは <strong> で強調する"
  lineBreakRules         String?  @db.Text  // 改行ルール（1行1ルール）例: "各段落は3〜4文以内にする"
  referenceImageUrl      String?  @db.Text  // デザイン参照画像（Vercel Blob）
  brandColors            Json?              // 参照画像から抽出したカラーパレット { primary, secondary, accent, background, text }
  createdAt              DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ─── ナレッジベース ───────────────────────────────────────────────
enum KnowledgeSourceType {
  URL
  MANUAL
  PDF
}

model KnowledgeSource {
  id        String              @id @default(cuid())
  tenantId  String
  projectId String?
  type      KnowledgeSourceType
  category  String              // case_study | service | company | other
  title     String
  url       String?
  content   String              @db.Text
  status    String              @default("ready") // ready | failed
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, category])
  @@index([projectId])
}

// ─── 管理者による事前登録アカウント ─────────────────────────────────
// 管理者がここに登録したEmailのみ /onboarding でテナント作成可能
model PendingTenant {
  id          String    @id @default(cuid())
  email       String    @unique
  companyName String
  createdAt   DateTime  @default(now())
  usedAt      DateTime? // オンボーディング完了時に設定
}

// PDF チャンクアップロード用一時テーブル (Inngest 処理後に削除)
model PdfUploadChunk {
  id         String   @id @default(cuid())
  tenantId   String
  uploadId   String
  chunkIndex Int
  data       Bytes
  createdAt  DateTime @default(now())

  @@unique([uploadId, chunkIndex])
  @@index([tenantId, uploadId])
}
